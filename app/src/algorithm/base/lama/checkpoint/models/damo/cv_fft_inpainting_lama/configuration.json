{
    "framework": "pytorch",
    "task": "image-inpainting",
    "pipeline":{
        "type": "fft-inpainting"
    },
    "model":{
        "type": "FFTInpainting",
        "pretrained": true
    },
    "dataset":{
        "type": "ImageInpaintingDataset",
        "name": "PlacesToyDataset",
        "mask_gen_kwargs":{
         "irregular_proba": 1,
         "irregular_kwargs":{
           "max_angle": 4,
           "max_len": 200,
           "max_width": 100,
           "max_times": 5,
           "min_times": 1
         },
         "box_proba": 1,
         "box_kwargs":{
           "margin": 10,
           "bbox_min_size": 30,
           "bbox_max_size": 150,
           "max_times": 3,
           "min_times": 1
           }
        },
        "train_out_size": 256,
        "val_out_size": 512
    },
    "preprocessor":{
    },
    "train": {
        "max_epochs": 2,
        "work_dir": "./work_dir",
        "dataloader": {
            "batch_size_per_gpu": 2,
            "workers_per_gpu": 4
        },
        "optimizer": {
            "type": "Adam",
            "weight_decay": 0.0005,
            "lr": 0.0001,
            "options":{
                "grad_clip":{
                    "max_norm":1
                }
            }
        },
        "lr_scheduler": {
            "type": "MultiStepLR",
            "milestones": [],
            "gamma": 0.1
        },
        "hooks": [{
                "type": "CheckpointHook",
                "interval": 1,
                "save_dir": "./work_dir"
            },
            {
                "type": "TextLoggerHook",
                "interval": 1,
                "out_dir": "./work_dir"
            },
            {
                "type": "IterTimerHook"
            },
            {
                "type": "EvaluationHook",
                "interval": 1
            }
        ]
    },
    "evaluation": {
        "dataloader": {
            "batch_size_per_gpu": 1,
            "workers_per_gpu": 4,
            "shuffle": false
        },
        "metrics": "image-inpainting-metric"
    }
}
